# SkillForge Configuration
# Copy to .env and fill in your values

# API Keys for LLM Providers
SKILLFORGE_DEEPSEEK_API_KEY=
SKILLFORGE_GEMINI_API_KEY=
SKILLFORGE_GROQ_API_KEY=

# Ollama (local inference)
SKILLFORGE_OLLAMA_BASE_URL=http://localhost:11434

# Execution Settings
SKILLFORGE_SANDBOX_ENABLED=true
SKILLFORGE_NETWORK_ENABLED=false
SKILLFORGE_EXECUTION_TIMEOUT=120
SKILLFORGE_MAX_MEMORY_MB=512

# Dashboard
SKILLFORGE_DASHBOARD_HOST=127.0.0.1
SKILLFORGE_DASHBOARD_PORT=7860

# Logging
SKILLFORGE_LOG_LEVEL=INFO

# Storage Location
SKILLFORGE_HOME=~/.skillforge
